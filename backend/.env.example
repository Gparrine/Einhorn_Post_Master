# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
# Optional: overrides backend/prompts/einhorn-gem.prompt.md
GEMINI_SYSTEM_PROMPT=
# Optional: custom path to prompt file
# GEMINI_PROMPT_FILE=prompts/einhorn-gem.prompt.md

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Facebook Group (manual-assist — copy + open group URL)
FACEBOOK_GROUP_URL=

# Meetup (manual-assist by default; optional GraphQL API with OAuth token)
MEETUP_GROUP_URLNAME=
MEETUP_API_KEY=

# Gymdesk (manual-assist — copy + open schedule)
GYMDESK_OPEN_URL=https://app.gymdesk.com/login
GYMDESK_MEMBER_SIGNUP_URL=https://einhornla.gymdesk.com/signup

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,https://gparrine.github.io

# Optional API speed bump — require X-API-Key on /api/refine and /api/post
# Set the same value as VITE_API_ACCESS_KEY in frontend/.env or GitHub Actions variable
API_ACCESS_KEY=

# Set to true to simulate posts when API keys are not configured
DEMO_MODE=true
